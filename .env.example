# NEON_DATABASE_URL: Neon PostgreSQL connection string (server-side only).
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/nilaya?sslmode=require"

# PORT: Express API server port (default 3001).
PORT=3001

# VITE_API_URL: Frontend API base URL override (leave empty for same-origin proxy).
# Only set this if deploying frontend and backend on separate origins.
VITE_API_URL=""

# SMTP: Email notification configuration for appointment bookings.
# Use your email provider's SMTP credentials (e.g., Gmail, Outlook, SendGrid).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
NOTIFICATION_EMAIL=""
