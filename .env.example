# NEON_DATABASE_URL: Neon PostgreSQL connection string (server-side only).
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/nilaya?sslmode=require"

# PORT: Express API server port (default 3001).
PORT=3001

# FRONTEND_URL: Hostinger frontend domain (for backend CORS policy configuration).
# Set to your production domain (e.g., https://yourdomain.com) or "*" to allow all origins.
FRONTEND_URL="*"

# VITE_API_URL: Frontend API base URL override.
# Set this to your backend Render URL (e.g., https://nilaya-api.onrender.com) during frontend build.
VITE_API_URL=""

# SMTP: Email notification configuration for appointment bookings.
# Use your email provider's SMTP credentials (e.g., Gmail, Outlook, Hostinger Email).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
NOTIFICATION_EMAIL=""
